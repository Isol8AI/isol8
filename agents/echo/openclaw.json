{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/agents/echo/workspace",
      "timeoutSeconds": 600,
      "blockStreamingDefault": "off"
    },
    "list": [
      {
        "id": "echo",
        "workspace": "~/.openclaw/agents/echo/workspace",
        "model": "qwen/qwen3.5-plus",
        "thinkingDefault": "low",
        "skills": [
          "gog",
          "slack",
          "fast-io",
          "taskr",
          "summarize",
          "meeting-prep",
          "n8n-workflow",
          "capability-evolver",
          "skill-vetter",
          "sona-security-audit"
        ],
        "tools": {
          "profile": "coding",
          "alsoAllow": ["lobster", "llm-task", "message"]
        }
      }
    ]
  },

  "plugins": {
    "entries": {
      "lobster": { "enabled": true },
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "qwen",
          "defaultModel": "qwen3.5-plus",
          "maxTokens": 1200,
          "timeoutMs": 45000
        }
      }
    }
  },

  "skills": {
    "entries": {
      "gog": { "enabled": true },
      "slack": { "enabled": true },
      "fast-io": { "enabled": true },
      "taskr": { "enabled": true },
      "summarize": { "enabled": true },
      "meeting-prep": { "enabled": true },
      "n8n-workflow": { "enabled": true },
      "capability-evolver": { "enabled": true },
      "skill-vetter": { "enabled": true },
      "sona-security-audit": { "enabled": true },
      "ms365": {
        "enabled": false,
        "note": "Click-to-connect: enabled per-user when they connect Microsoft Teams (for meeting transcripts via Graph API) or Outlook in settings"
      },
      "hubspot": {
        "enabled": false,
        "note": "Click-to-connect: enabled per-user when they select HubSpot as their CRM in settings"
      },
      "attio-enhanced": {
        "enabled": false,
        "note": "Click-to-connect: enabled per-user when they select Attio as their CRM in settings"
      }
    }
  },

  "tools": {
    "deny": [
      "foxreach-io",
      "campaign-orchestrator",
      "phone-caller"
    ]
  },

  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 3,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [30000, 60000, 120000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "24h"
  },

  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOK_TOKEN}",
    "path": "/hooks"
  },

  "channels": {
    "slack": { "enabled": true }
  }
}
