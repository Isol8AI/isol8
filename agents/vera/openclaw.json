{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/agents/vera/workspace",
      "timeoutSeconds": 600,
      "blockStreamingDefault": "off"
    },
    "list": [
      {
        "id": "vera",
        "workspace": "~/.openclaw/agents/vera/workspace",
        "model": "qwen/qwen3.5-plus",
        "thinkingDefault": "low",
        "skills": [
          "slack",
          "gog",
          "summarize",
          "capability-evolver",
          "fast-io",
          "taskr",
          "skill-vetter",
          "sona-security-audit",
          "n8n-workflow",
          "telcall-twilio",
          "local-rag-qdrant",
          "agent-browser"
        ],
        "tools": {
          "profile": "coding",
          "alsoAllow": ["lobster", "llm-task", "message"]
        }
      }
    ]
  },

  "plugins": {
    "entries": {
      "lobster": { "enabled": true },
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "qwen",
          "defaultModel": "qwen3.5-plus",
          "maxTokens": 800,
          "timeoutMs": 30000
        }
      }
    }
  },

  "skills": {
    "entries": {
      "slack": { "enabled": true },
      "gog": { "enabled": true },
      "summarize": { "enabled": true },
      "capability-evolver": { "enabled": true },
      "fast-io": { "enabled": true },
      "taskr": { "enabled": true },
      "skill-vetter": { "enabled": true },
      "sona-security-audit": { "enabled": true },
      "n8n-workflow": { "enabled": true },
      "telcall-twilio": {
        "enabled": true,
        "env": { "TWILIO_ACCOUNT_SID": "${TWILIO_ACCOUNT_SID}", "TWILIO_AUTH_TOKEN": "${TWILIO_AUTH_TOKEN}" }
      },
      "local-rag-qdrant": {
        "enabled": true,
        "config": {
          "collection": "vera-knowledge-base",
          "similarity_threshold": 0.75
        }
      },
      "agent-browser": { "enabled": true },

      "linkedin-automation": { "enabled": false },
      "salesforce-api": { "enabled": false },
      "pipedrive-api": { "enabled": false },
      "attio-api": { "enabled": false }
    }
  },

  "tools": {
    "deny": [
      "foxreach-io",
      "campaign-orchestrator",
      "phone-caller",
      "linkedin-automation",
      "api-gateway",
      "tavily",
      "firecrawl"
    ]
  },

  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 2,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "24h"
  },

  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOK_TOKEN}",
    "path": "/hooks"
  },

  "channels": {
    "slack": {
      "enabled": true
    }
  }
}
