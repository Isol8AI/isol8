{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/agents/pitch/workspace",
      "timeoutSeconds": 600,
      "blockStreamingDefault": "off"
    },
    "list": [
      {
        "id": "pitch",
        "workspace": "~/.openclaw/agents/pitch/workspace",
        "model": "qwen/qwen3.5-plus",
        "thinkingDefault": "low",
        "skills": [
          "agent-browser",
          "gog",
          "slack",
          "fast-io",
          "summarize",
          "business-development",
          "social-intelligence",
          "capability-evolver",
          "skill-vetter",
          "sona-security-audit",
          "n8n-workflow"
        ],
        "tools": {
          "profile": "coding",
          "alsoAllow": ["lobster", "llm-task", "message"]
        }
      }
    ]
  },

  "plugins": {
    "entries": {
      "lobster": { "enabled": true },
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "qwen",
          "defaultModel": "qwen3.5-plus",
          "maxTokens": 800,
          "timeoutMs": 30000
        }
      }
    }
  },

  "skills": {
    "entries": {
      "agent-browser": { "enabled": true },
      "gog": { "enabled": true },
      "slack": { "enabled": true },
      "fast-io": { "enabled": true },
      "summarize": { "enabled": true },
      "business-development": { "enabled": true },
      "social-intelligence": { "enabled": true },
      "capability-evolver": { "enabled": true },
      "skill-vetter": { "enabled": true },
      "sona-security-audit": { "enabled": true },
      "n8n-workflow": { "enabled": true },

      "hubspot-crm": { "enabled": false },
      "salesforce-crm": { "enabled": false },
      "attio-crm": { "enabled": false },
      "pipedrive-crm": { "enabled": false },

      "instantly-outbound": { "enabled": false },
      "smartlead-outbound": { "enabled": false },
      "mailshake-outbound": { "enabled": false },
      "lemlist-outbound": { "enabled": false }
    }
  },

  "tools": {
    "deny": [
      "salesforce-api",
      "pipedrive-api",
      "attio-api",
      "tavily",
      "foxreach-io",
      "campaign-orchestrator",
      "attio-enhanced"
    ]
  },

  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 1,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "24h"
  },

  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOK_TOKEN}",
    "path": "/hooks"
  },

  "channels": {
    "slack": {
      "enabled": true
    }
  }
}
