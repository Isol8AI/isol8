{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/agents/thread/workspace",
      "timeoutSeconds": 300,
      "blockStreamingDefault": "off"
    },
    "list": [
      {
        "id": "thread",
        "workspace": "~/.openclaw/agents/thread/workspace",
        "model": "qwen/qwen3.5-plus",
        "thinkingDefault": "low",
        "skills": [
          "gog",
          "email-security",
          "slack",
          "fast-io",
          "taskr",
          "summarize",
          "n8n-workflow",
          "capability-evolver",
          "skill-vetter",
          "sona-security-audit"
        ],
        "tools": {
          "profile": "coding",
          "alsoAllow": ["lobster", "llm-task", "message"]
        }
      }
    ]
  },

  "plugins": {
    "entries": {
      "lobster": { "enabled": true },
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "qwen",
          "defaultModel": "qwen3.5-plus",
          "maxTokens": 600,
          "timeoutMs": 20000
        }
      }
    }
  },

  "skills": {
    "entries": {
      "gog": { "enabled": true },
      "email-security": { "enabled": true },
      "slack": { "enabled": true },
      "fast-io": { "enabled": true },
      "taskr": { "enabled": true },
      "summarize": { "enabled": true },
      "n8n-workflow": { "enabled": true },
      "capability-evolver": { "enabled": true },
      "skill-vetter": { "enabled": true },
      "sona-security-audit": { "enabled": true },
      "himalaya": { "enabled": false, "note": "Enable for non-Google IMAP/SMTP accounts" }
    }
  },

  "tools": {
    "deny": [
      "foxreach-io",
      "campaign-orchestrator",
      "phone-caller",
      "private-web-search-searchxng"
    ]
  },

  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 2,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [30000, 60000, 120000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "24h"
  },

  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOK_TOKEN}",
    "path": "/hooks"
  },

  "channels": {
    "slack": { "enabled": true },
    "whatsapp": { "enabled": false, "note": "Enable via native OpenClaw channel" },
    "telegram": { "enabled": false, "note": "Enable via native OpenClaw channel" },
    "signal": { "enabled": false, "note": "Enable via native OpenClaw channel" },
    "discord": { "enabled": false, "note": "Enable via native OpenClaw channel" }
  }
}
