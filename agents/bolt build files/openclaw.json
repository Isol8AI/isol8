{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/agents/bolt/workspace",
      "timeoutSeconds": 600,
      "blockStreamingDefault": "off"
    },
    "list": [
      {
        "id": "bolt",
        "workspace": "~/.openclaw/agents/bolt/workspace",
        "model": "qwen/qwen3.5-plus",
        "thinkingDefault": "low",
        "skills": [
          "github",
          "linear",
          "vercel",
          "railway",
          "slack",
          "capability-evolver",
          "taskr",
          "fast-io",
          "summarize",
          "skill-vetter",
          "sona-security-audit",
          "n8n-workflow"
        ],
        "tools": {
          "profile": "coding",
          "alsoAllow": ["lobster", "llm-task", "message"],
          "deny": [
            "auto-merge",
            "force-push",
            "delete-branch-protected",
            "production-deploy-unreviewed",
            "secrets-scanner-bypass",
            "env-var-write",
            "db-migration-run"
          ]
        },
        "sandbox": {
          "enabled": true,
          "network": "restricted",
          "allowedHosts": [
            "api.github.com",
            "api.linear.app",
            "api.vercel.com",
            "api.railway.app"
          ]
        },
        "llm": {
          "maxTokens": 2000,
          "timeoutMs": 60000
        }
      }
    ]
  },

  "plugins": {
    "entries": {
      "lobster": { "enabled": true },
      "llm-task": { "enabled": true },
      "node-runner": { "enabled": true }
    }
  },

  "skills": {
    "entries": {
      "github": {
        "enabled": true,
        "env": { "GITHUB_TOKEN": "${GITHUB_TOKEN}" }
      },
      "linear": {
        "enabled": true,
        "env": { "LINEAR_API_KEY": "${LINEAR_API_KEY}" }
      },
      "vercel": {
        "enabled": true,
        "env": { "VERCEL_TOKEN": "${VERCEL_TOKEN}" }
      },
      "railway": {
        "enabled": true,
        "env": { "RAILWAY_TOKEN": "${RAILWAY_TOKEN}" }
      },
      "slack": { "enabled": true },
      "fast-io": { "enabled": true },
      "taskr": { "enabled": true },
      "summarize": { "enabled": true },
      "n8n-workflow": { "enabled": true },
      "capability-evolver": { "enabled": true },
      "skill-vetter": { "enabled": true },
      "sona-security-audit": { "enabled": true },
      "gitlab": {
        "enabled": false,
        "note": "Enable if team uses GitLab instead of GitHub"
      },
      "jira": {
        "enabled": false,
        "note": "Enable if team uses Jira instead of Linear"
      },
      "netlify": {
        "enabled": false,
        "note": "Enable if deploying on Netlify instead of Vercel"
      },
      "sentry": {
        "enabled": false,
        "note": "Enable for error monitoring ingestion"
      },
      "datadog": {
        "enabled": false,
        "note": "Enable for infra monitoring"
      }
    }
  },

  "tools": {
    "deny": [
      "auto-merge",
      "force-push",
      "delete-branch-protected",
      "production-deploy-unreviewed",
      "secrets-scanner-bypass",
      "env-var-write",
      "db-migration-run"
    ]
  },

  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 2,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "24h",
    "jobs": [
      {
        "id": "bolt-hygiene-sweep",
        "cron": "0 9 * * 1",
        "pipeline": "repo-hygiene-sweep.lobster",
        "description": "Weekly repo hygiene scan — stale branches, idle PRs, old issues"
      },
      {
        "id": "bolt-deploy-health",
        "cron": "0 8 * * *",
        "pipeline": "deploy-health-check.lobster",
        "description": "Daily production health check across all services"
      },
      {
        "id": "bolt-bug-digest",
        "cron": "0 9 * * 1",
        "pipeline": "bug-digest.lobster",
        "description": "Weekly bug digest — open issues ranked by severity"
      }
    ]
  },

  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOK_TOKEN}",
    "path": "/hooks",
    "routes": [
      {
        "path": "/hooks/github",
        "pipeline": "pr-summary.lobster",
        "events": ["pull_request.opened", "pull_request.synchronize"]
      },
      {
        "path": "/hooks/deploy",
        "pipeline": "cicd-monitor.lobster",
        "events": ["deployment.failed", "deployment.error"]
      }
    ]
  },

  "channels": {
    "slack": { "enabled": true }
  }
}
