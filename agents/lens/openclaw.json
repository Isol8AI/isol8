{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/agents/lens/workspace",
      "timeoutSeconds": 900,
      "blockStreamingDefault": "off"
    },
    "list": [
      {
        "id": "lens",
        "workspace": "~/.openclaw/agents/lens/workspace",
        "model": "qwen/qwen3.5-plus",
        "thinkingDefault": "low",
        "skills": [
          "agent-browser",
          "fast-io",
          "taskr",
          "summarize",
          "gog",
          "slack",
          "n8n-workflow",
          "capability-evolver",
          "skill-vetter",
          "sona-security-audit",
          "deeps"
        ],
        "tools": {
          "profile": "coding",
          "alsoAllow": ["lobster", "llm-task", "message"]
        }
      }
    ]
  },

  "plugins": {
    "entries": {
      "lobster": { "enabled": true },
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "qwen",
          "defaultModel": "qwen3.5-plus",
          "maxTokens": 1500,
          "timeoutMs": 60000
        }
      }
    }
  },

  "skills": {
    "entries": {
      "agent-browser": { "enabled": true },
      "fast-io": { "enabled": true },
      "taskr": { "enabled": true },
      "summarize": { "enabled": true },
      "gog": { "enabled": true },
      "slack": { "enabled": true },
      "n8n-workflow": { "enabled": true },
      "capability-evolver": { "enabled": true },
      "skill-vetter": { "enabled": true },
      "sona-security-audit": { "enabled": true },
      "deeps": { "enabled": true },
      "arxiv-search-collector": { "enabled": false, "note": "Enable for academic/tech verticals" },
      "agentic-paper-digest": { "enabled": false, "note": "Enable for academic monitoring" },
      "arxiv-watcher": { "enabled": false, "note": "Enable for academic topic monitoring" },
      "pubmed-edirect": { "enabled": false, "note": "Enable for healthcare/life sciences" },
      "stackunderflow": { "enabled": false, "note": "Enable for tech vertical community tier" },
      "depo-bot": { "enabled": false, "note": "Enable for legal vertical" },
      "social-intelligence": { "enabled": false, "note": "Enable for competitive/market verticals" }
    }
  },

  "tools": {
    "deny": [
      "tavily",
      "firecrawl",
      "openclaw-aisa-search-web-academic-tavily",
      "foxreach-io",
      "campaign-orchestrator",
      "phone-caller",
      "linkedin-automation",
      "private-web-search-searchxng"
    ]
  },

  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 2,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "24h"
  },

  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOK_TOKEN}",
    "path": "/hooks"
  },

  "channels": {
    "slack": { "enabled": true }
  }
}
