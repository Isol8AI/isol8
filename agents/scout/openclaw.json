{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/agents/scout/workspace",
      "timeoutSeconds": 600,
      "blockStreamingDefault": "off"
    },
    "list": [
      {
        "id": "scout",
        "workspace": "~/.openclaw/agents/scout/workspace",
        "model": "qwen/qwen3.5-plus",
        "thinkingDefault": "low",
        "skills": [
          "apollo",
          "agent-browser",
          "gog",
          "slack",
          "capability-evolver",
          "taskr",
          "fast-io",
          "summarize",
          "last30days",
          "skill-vetter",
          "sona-security-audit",
          "n8n-workflow"
        ],
        "tools": {
          "profile": "coding",
          "alsoAllow": ["lobster", "llm-task", "message"],
          "deny": [
            "foxreach-io",
            "campaign-orchestrator",
            "phone-caller",
            "firecrawl",
            "tavily",
            "api-gateway"
          ]
        }
      }
    ]
  },

  "plugins": {
    "entries": {
      "lobster": { "enabled": true },
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "qwen",
          "defaultModel": "qwen3.5-plus",
          "maxTokens": 800,
          "timeoutMs": 30000
        }
      }
    }
  },

  "skills": {
    "entries": {
      "apollo": {
        "enabled": true,
        "env": { "APOLLO_API_KEY": "${APOLLO_API_KEY}" }
      },
      "agent-browser": { "enabled": true },
      "gog": { "enabled": true },
      "slack": { "enabled": true },
      "capability-evolver": { "enabled": true },
      "taskr": { "enabled": true },
      "fast-io": { "enabled": true },
      "summarize": { "enabled": true },
      "last30days": { "enabled": true },
      "skill-vetter": { "enabled": true },
      "sona-security-audit": { "enabled": true },
      "n8n-workflow": { "enabled": true },
      "hubspot-crm": { "enabled": false, "note": "Click-to-connect: enabled per-user when they connect HubSpot as their CRM in settings" },
      "salesforce-crm": { "enabled": false, "note": "Click-to-connect: enabled per-user when they connect Salesforce as their CRM in settings" },
      "attio-crm": { "enabled": false, "note": "Click-to-connect: enabled per-user when they connect Attio as their CRM in settings" },
      "pipedrive-crm": { "enabled": false, "note": "Click-to-connect: enabled per-user when they connect Pipedrive as their CRM in settings" }
    }
  },

  "tools": {
    "deny": [
      "foxreach-io",
      "campaign-orchestrator",
      "phone-caller",
      "linkedin-automation",
      "firecrawl",
      "tavily",
      "api-gateway"
    ]
  },

  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 1,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "24h"
  },

  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOK_TOKEN}",
    "path": "/hooks"
  },

  "channels": {
    "slack": {
      "enabled": true
    }
  }
}
