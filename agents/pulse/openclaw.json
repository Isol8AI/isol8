{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/agents/pulse/workspace",
      "timeoutSeconds": 600,
      "blockStreamingDefault": "off"
    },
    "list": [
      {
        "id": "pulse",
        "workspace": "~/.openclaw/agents/pulse/workspace",
        "model": "qwen/qwen3.5-plus",
        "thinkingDefault": "low",
        "skills": [
          "tavily",
          "agent-browser",
          "gog",
          "slack",
          "fast-io",
          "taskr",
          "summarize",
          "n8n-workflow",
          "capability-evolver",
          "skill-vetter",
          "sona-security-audit",
          "biz-reporter",
          "reef-copywriting",
          "content-creator",
          "b2c-marketing",
          "brw-newsletter-creation-curation",
          "adaptlypost",
          "posthog",
          "performance-reporter"
        ],
        "tools": {
          "profile": "coding",
          "alsoAllow": ["lobster", "llm-task", "message"]
        }
      }
    ]
  },

  "plugins": {
    "entries": {
      "lobster": { "enabled": true },
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "qwen",
          "defaultModel": "qwen3.5-plus",
          "maxTokens": 1200,
          "timeoutMs": 45000
        }
      }
    }
  },

  "skills": {
    "entries": {
      "tavily": {
        "enabled": true,
        "env": { "TAVILY_API_KEY": "${TAVILY_API_KEY}" }
      },
      "agent-browser": { "enabled": true },
      "gog": { "enabled": true },
      "slack": { "enabled": true },
      "fast-io": { "enabled": true },
      "taskr": { "enabled": true },
      "summarize": { "enabled": true },
      "n8n-workflow": { "enabled": true },
      "capability-evolver": { "enabled": true },
      "skill-vetter": { "enabled": true },
      "sona-security-audit": { "enabled": true },
      "biz-reporter": { "enabled": true },
      "reef-copywriting": { "enabled": true },
      "content-creator": { "enabled": true },
      "b2c-marketing": { "enabled": true },
      "brw-newsletter-creation-curation": { "enabled": true },
      "adaptlypost": {
        "enabled": true,
        "env": { "ADAPTLYPOST_API_KEY": "${ADAPTLYPOST_API_KEY}" },
        "config": { "default_mode": "draft" }
      },
      "posthog": {
        "enabled": true,
        "env": { "POSTHOG_API_KEY": "${POSTHOG_API_KEY}" }
      },
      "performance-reporter": { "enabled": true }
    }
  },

  "tools": {
    "deny": [
      "foxreach-io",
      "campaign-orchestrator",
      "phone-caller",
      "linkedin-automation"
    ]
  },

  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 2,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "24h"
  },

  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOK_TOKEN}",
    "path": "/hooks"
  },

  "channels": {
    "slack": {
      "enabled": true
    }
  }
}
