{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/agents/ember/workspace",
      "timeoutSeconds": 600,
      "blockStreamingDefault": "off"
    },
    "list": [
      {
        "id": "ember",
        "workspace": "~/.openclaw/agents/ember/workspace",
        "model": "qwen/qwen3.5-plus",
        "thinkingDefault": "low",
        "skills": [
          "gog",
          "slack",
          "fast-io",
          "taskr",
          "summarize",
          "n8n-workflow",
          "capability-evolver",
          "skill-vetter",
          "sona-security-audit",
          "agentgate",
          "agent-browser"
        ],
        "tools": {
          "profile": "coding",
          "alsoAllow": ["lobster", "llm-task", "message"]
        }
      }
    ]
  },

  "plugins": {
    "entries": {
      "lobster": { "enabled": true },
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "qwen",
          "defaultModel": "qwen3.5-plus",
          "maxTokens": 800,
          "timeoutMs": 30000
        }
      }
    }
  },

  "skills": {
    "entries": {
      "gog": { "enabled": true },
      "slack": { "enabled": true },
      "fast-io": { "enabled": true },
      "taskr": { "enabled": true },
      "summarize": { "enabled": true },
      "n8n-workflow": { "enabled": true },
      "capability-evolver": { "enabled": true },
      "skill-vetter": { "enabled": true },
      "sona-security-audit": { "enabled": true },
      "agentgate": { "enabled": true },
      "agent-browser": { "enabled": true },
      "hire": { "enabled": false, "note": "Enable for sub-agent scaffolding only — never for candidate evaluation" }
    }
  },

  "tools": {
    "deny": [
      "foxreach-io",
      "campaign-orchestrator",
      "phone-caller",
      "zoho-recruit",
      "zoho-crm",
      "gmail"
    ]
  },

  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 2,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "24h"
  },

  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOK_TOKEN}",
    "path": "/hooks"
  },

  "channels": {
    "slack": { "enabled": true }
  }
}
