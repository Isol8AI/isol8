{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/agents/ora/workspace",
      "timeoutSeconds": 600,
      "blockStreamingDefault": "off"
    },
    "list": [
      {
        "id": "ora",
        "workspace": "~/.openclaw/agents/ora/workspace",
        "model": "qwen/qwen3.5-plus",
        "thinkingDefault": "low",
        "skills": [
          "gog",
          "slack",
          "fast-io",
          "taskr",
          "summarize",
          "meeting-prep",
          "n8n-workflow",
          "capability-evolver",
          "skill-vetter",
          "sona-security-audit"
        ],
        "tools": {
          "profile": "coding",
          "alsoAllow": ["lobster", "llm-task", "message"]
        }
      }
    ]
  },

  "plugins": {
    "entries": {
      "lobster": { "enabled": true },
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "qwen",
          "defaultModel": "qwen3.5-plus",
          "maxTokens": 800,
          "timeoutMs": 30000
        }
      }
    }
  },

  "skills": {
    "entries": {
      "caldav-calendar": {
        "enabled": false,
        "note": "Click-to-connect: enabled per-user when they connect iCloud / Fastmail / Nextcloud / generic CalDAV in settings",
        "config": {
          "credential_store": "os_keyring",
          "config_path": "~/.config/vdirsyncer/"
        }
      },
      "ms365": {
        "enabled": false,
        "note": "Click-to-connect: enabled per-user when they connect Microsoft 365 / Outlook in settings"
      },
      "calctl": {
        "enabled": false,
        "note": "Click-to-connect: enabled per-user on macOS when they connect Apple Calendar in settings"
      },
      "gog": { "enabled": true },
      "slack": { "enabled": true },
      "fast-io": { "enabled": true },
      "taskr": { "enabled": true },
      "summarize": { "enabled": true },
      "meeting-prep": { "enabled": true },
      "n8n-workflow": { "enabled": true },
      "capability-evolver": { "enabled": true },
      "skill-vetter": { "enabled": true },
      "sona-security-audit": { "enabled": true }
    }
  },

  "tools": {
    "deny": [
      "foxreach-io",
      "campaign-orchestrator",
      "phone-caller",
      "linkedin-automation"
    ]
  },

  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 2,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "24h"
  },

  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOK_TOKEN}",
    "path": "/hooks"
  },

  "channels": {
    "slack": {
      "enabled": true
    }
  }
}
