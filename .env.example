# Clerk Auth (required)
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev

# Database - LOCAL DEVELOPMENT ONLY
# Uses local Docker PostgreSQL (see docker-compose.yml)
# DO NOT use Supabase connection strings here!
# ./start_dev.sh will override this with the local Docker URL anyway
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/securechat

# For deployed environments (dev/staging/prod), DATABASE_URL is set via:
# - GitHub Actions secrets (CI/CD)
# - EC2 instance .env files (managed separately)

# HuggingFace Inference Providers (required for LLM features)
HUGGINGFACE_TOKEN=hf_your_token_here
HF_API_URL=https://router.huggingface.co/v1

# OpenClaw Agent Tools (optional)
# Enables web search for agents. Get a key at https://brave.com/search/api/
# BRAVE_API_KEY=BSA...

# Fernet key for encrypting BYOK API keys at rest (required in production)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# Debug mode (set to true to enable SQL logging)
# DEBUG=false
