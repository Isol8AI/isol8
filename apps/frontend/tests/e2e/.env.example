# apps/frontend/tests/e2e/.env.example
# Copy to apps/frontend/.env.local and fill in values for local e2e runs.

# Where the e2e runs against. dev URL or localhost:3000.
BASE_URL=https://dev.isol8.co

# Backend API URL — must include /api/v1 suffix.
NEXT_PUBLIC_API_URL=https://api-dev.isol8.co/api/v1

# Clerk dev keys (from https://dashboard.clerk.com → API Keys).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Stripe test-mode (from https://dashboard.stripe.com/test/apikeys).
STRIPE_SECRET_KEY=sk_test_...

# Stripe Starter price ID for dev (from Stripe dashboard → Products).
STRIPE_STARTER_PRICE_ID=price_1TF5MDI54BysGS3rlT80MMI8

# Vercel preview auth bypass (from Vercel dashboard → Settings → Deployment Protection).
VERCEL_AUTOMATION_BYPASS_SECRET=
