# === LocalStack Local Development Environment ===
# This file is sourced when running the backend against LocalStack.
# Docker Compose overrides AWS_ENDPOINT_URL, DATABASE_URL, and
# WS_MANAGEMENT_API_URL with Docker DNS names.

# Environment
ENVIRONMENT=local
DEBUG=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Bedrock disabled — using Ollama for local inference
BEDROCK_ENABLED=false

# Database (overridden by docker-compose for Docker DNS)
# DATABASE_URL is dynamically set in localstack/generated.env after CDK deploy
# (port and credentials are read from LocalStack RDS + Secrets Manager)

# ECS
ECS_CLUSTER_ARN=arn:aws:ecs:us-east-1:000000000000:cluster/isol8-local
ECS_TASK_DEFINITION=isol8-local-openclaw
ECS_SUBNETS=subnet-local1
ECS_SECURITY_GROUP_ID=sg-local1

# Cloud Map (populated by localstack/generated.env at runtime)
CLOUD_MAP_NAMESPACE_ID=placeholder
CLOUD_MAP_SERVICE_ID=placeholder
CLOUD_MAP_SERVICE_ARN=placeholder

# EFS (populated by localstack/generated.env at runtime)
EFS_MOUNT_PATH=/mnt/efs/users
EFS_FILE_SYSTEM_ID=placeholder

# Container IAM
CONTAINER_EXECUTION_ROLE_ARN=arn:aws:iam::000000000000:role/local-exec

# OpenClaw
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# WebSocket (overridden by docker-compose for Docker DNS)
WS_MANAGEMENT_API_URL=http://localhost:4566/@connections
WS_CONNECTIONS_TABLE=isol8-local-websocket-connections

# S3
S3_CONFIG_BUCKET=isol8-local-openclaw-configs

# Clerk (real dev-mode keys — set these in your shell or .env file)
CLERK_ISSUER=${CLERK_ISSUER:-https://your-clerk-dev.clerk.accounts.dev}
CLERK_SECRET_KEY=${CLERK_SECRET_KEY:-}

# Stripe (real test-mode keys)
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY:-}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET:-}
STRIPE_METER_ID=${STRIPE_METER_ID:-}
STRIPE_STARTER_FIXED_PRICE_ID=${STRIPE_STARTER_FIXED_PRICE_ID:-}
STRIPE_PRO_FIXED_PRICE_ID=${STRIPE_PRO_FIXED_PRICE_ID:-}
STRIPE_METERED_PRICE_ID=${STRIPE_METERED_PRICE_ID:-}

# Billing
BILLING_MARKUP=1.4

# Encryption (populated by seed script)
ENCRYPTION_KEY=placeholder

# CORS
CORS_ORIGINS=http://localhost:3000

# Proxy (overridden by docker-compose for Docker DNS)
PROXY_BASE_URL=http://localhost:8000/api/v1/proxy
FRONTEND_URL=http://localhost:3000
