{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "identifier": "default",
  "description": "Default capabilities for Isol8 desktop",
  "windows": ["main"],
  "remote": {
    "urls": ["https://dev.isol8.co/*", "https://app.isol8.co/*"]
  },
  "permissions": [
    "core:default",
    "deep-link:default",
    "shell:allow-open",
    "notification:default"
  ]
}
